# PaperEval Environment Configuration
# ===================================
# Copy this file to .env and update values as needed

# Application Settings
APP_NAME=PaperEval
DEBUG=True

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Database (Choose one)
# SQLite (Default - Good for development)
DATABASE_URL=sqlite:///./papereval.db

# PostgreSQL (Recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/papereval

# MongoDB (Alternative)
# DATABASE_URL=mongodb://localhost:27017/papereval

# ========== OCR Settings ==========
OCR_ENGINE=easyocr
# Options: ensemble, easyocr, tesseract, paddleocr, sarvam
# - easyocr: Balanced (default, 85-90% accuracy, ~5s)
# - ensemble: Best accuracy (90-95%, ~12s, runs 3 engines in parallel)
# - tesseract: Fast (80-85%, ~3s)
# - paddleocr: Layouts (85-90%, ~8s)
# - sarvam: Cloud API (90-95%, requires API key)

OCR_LANGUAGES=["en"]
FAST_OCR_MODE=true
LOW_MEMORY_MODE=false

# TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe

# ========== Sarvam AI OCR Settings ==========
# Get API key from: https://console.sarvam.ai/
SARVAM_API_KEY=sk_059fh0vj_KhBryRQHeBzwI1KdG5a7WPY9
SARVAM_API_URL=https://api.sarvam.ai/v1/document-intelligence

# ========== Optional Cloud OCR APIs ==========
# Google Cloud Vision (for Sarvam fallback)
# GOOGLE_CLOUD_API_KEY=your_key_here
# Get from: https://console.cloud.google.com/apis/credentials

# OCR.space (free fallback, no key needed)
# OCRSPACE_API_KEY=K88888888888957

# ========== NLP Settings ==========
SPACY_MODEL=en_core_web_sm
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ========== Scoring Weights (must sum to 1.0) ==========
WEIGHT_SEMANTIC=0.6
WEIGHT_KEYWORD=0.2
WEIGHT_DIAGRAM=0.2

# ========== Semantic Thresholds ==========
SEMANTIC_EXCELLENT_THRESHOLD=0.85
SEMANTIC_GOOD_THRESHOLD=0.70
SEMANTIC_AVERAGE_THRESHOLD=0.50
